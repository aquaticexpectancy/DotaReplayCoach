# Copy to .env and fill in. Each value must be on its OWN line, directly after
# the "KEY=" with no comment text in front of it and no line breaks inside the value.

STRATZ_TOKEN=paste-the-whole-stratz-bearer-token-here

# Optional — enables AI coaching (`main.py --coach`). Without it the report
# still generates, just without the Coach blocks.
XAI_API_KEY=paste-your-xai-key-here
